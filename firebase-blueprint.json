{
  "entities": {
    "FoodItem": {
      "title": "Food Item",
      "description": "Details of a menu item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Tiffins", "Lunch", "Dinner", "Cool Drinks", "Juices"] },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "isOffer": { "type": "boolean" },
        "offerText": { "type": "string" },
        "isRecommended": { "type": "boolean" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Public and private user information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Details of a customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "delivered", "cancelled"] },
        "createdAt": { "type": "number" },
        "deliveryAddress": { "type": "string" },
        "paymentMethod": { "type": "string" }
      },
      "required": ["userId", "items", "total", "status", "deliveryAddress"]
    }
  },
  "firestore": {
    "/menu/{itemId}": {
      "schema": "FoodItem",
      "description": "Collection of available food items"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order documents"
    }
  }
}
